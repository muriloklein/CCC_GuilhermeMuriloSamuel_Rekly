generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  criado_em DateTime @default(now())

  // Relações (serão usadas nas próximas entregas)
  assinaturas          Assinatura[]
  notificacoes         Notificacao[]
  preferenciasNotif    PreferenciaNotificacao?
  logs                 Log[]
  sugestoesEconomia    SugestaoEconomia[]

  @@map("usuarios")
}

model PreferenciaNotificacao {
  id                   Int     @id @default(autoincrement())
  usuario_id           Int     @unique
  notificar_vencimento Boolean @default(true)
  notificar_atraso     Boolean @default(true)

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("preferencias_notificacao")
}

model Log {
  id           Int      @id @default(autoincrement())
  usuario_id   Int?
  acao         String
  tabela_afetada String?
  registro_id  Int?
  criado_em    DateTime @default(now())

  usuario Usuario? @relation(fields: [usuario_id], references: [id])

  @@map("logs")
}

// Tabelas das próximas entregas (criadas agora para não migrar depois)

model Categoria {
  id         Int          @id @default(autoincrement())
  nome       String
  is_padrao  Boolean      @default(false)
  usuario_id Int?

  assinaturas Assinatura[]

  @@map("categorias")
}

model Assinatura {
  id           Int      @id @default(autoincrement())
  usuario_id   Int
  categoria_id Int
  nome_servico String
  valor        Decimal
  moeda        String   @default("BRL")
  periodo      String   // mensal, trimestral, semestral, anual
  data_inicio  DateTime
  dia_cobranca Int
  status       String   @default("ativo") // ativo, teste, cancelado
  participantes Int     @default(1)
  criado_em    DateTime @default(now())

  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  categoria Categoria @relation(fields: [categoria_id], references: [id])
  pagamentos Pagamento[]
  sugestoes  SugestaoEconomia[]

  @@map("assinaturas")
}

model Pagamento {
  id             Int      @id @default(autoincrement())
  assinatura_id  Int
  valor          Decimal
  data_pagamento DateTime
  status         String   // pago, pendente, atrasado

  assinatura Assinatura @relation(fields: [assinatura_id], references: [id])

  @@map("pagamentos")
}

model Notificacao {
  id         Int      @id @default(autoincrement())
  usuario_id Int
  tipo       String   // vencimento, atraso
  mensagem   String
  enviado_em DateTime @default(now())
  lido       Boolean  @default(false)

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("notificacoes")
}

model SugestaoEconomia {
  id            Int      @id @default(autoincrement())
  usuario_id    Int
  assinatura_id Int
  tipo          String   // sobreposicao, desuso
  descricao     String
  dispensada    Boolean  @default(false)
  exibida       Boolean  @default(true)
  criado_em     DateTime @default(now())

  usuario    Usuario    @relation(fields: [usuario_id], references: [id])
  assinatura Assinatura @relation(fields: [assinatura_id], references: [id])

  @@map("sugestoes_economia")
}